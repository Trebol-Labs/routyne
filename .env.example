# ============================================================================
# ROUTYNE - Environment Variables Reference
# ============================================================================
# Copy this file to .env.local to set up your local development environment.
# Values marked with ⚠️ are required for production.
#
# For current app status and general docs, see `status.md` and `agents.md`.
# ============================================================================

# Public URL used for canonical links, Open Graph metadata, and share copy.
# Defaults to https://routyne-nu.vercel.app when omitted.
NEXT_PUBLIC_SITE_URL=https://routyne-nu.vercel.app

# ============================================================================
# ⚠️ REQUIRED - Exercise Database Integration
# ============================================================================
# API key for ExerciseDB (RapidAPI) - needed for exercise media (GIFs, images)
# and exercise search functionality.
# Get one at: https://rapidapi.com/api-details/api/exercise-db
RAPIDAPI_KEY=your_rapidapi_key_here

# ============================================================================
# OPTIONAL - Cloud Sync & Authentication (Supabase)
# ============================================================================
# These enable cloud synchronization of workout history, user profiles,
# and optional cloud backup. Leave blank if you only want local storage.

# Supabase project URL (shown in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous API key (public key for client-side auth)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================================================
# OPTIONAL - AI Coach (Vercel AI Gateway + Claude)
# ============================================================================
# Enable the AI Coach feature and Vercel AI Gateway authentication.
# Requires VERCEL_OIDC_TOKEN for production.

# Set to 'true' to show the AI Coach button in the UI
NEXT_PUBLIC_COACH_ENABLED=false

# Vercel OIDC token for AI Gateway authentication
# Obtain via: vercel link && vercel env pull
VERCEL_OIDC_TOKEN=your_vercel_oidc_token

# Maximum AI Coach calls per day for free tier users (default: 5)
COACH_DAILY_LIMIT_FREE=5

# ============================================================================
# OPTIONAL - Push Notifications (Web Push API with VAPID)
# ============================================================================
# Enable browser push notifications for rest timers and reminders.
# Generate keys via: node scripts/generate-vapid-keys.mjs

# VAPID public key (used by the browser)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# VAPID public key (server-side copy used by push routes)
VAPID_PUBLIC_KEY=your_vapid_public_key_here

# VAPID private key (server-side only, never expose to browser)
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# VAPID subject (contact email for push service, format: mailto:your-email@example.com)
VAPID_SUBJECT=mailto:your-email@example.com

# Note: NEXT_PUBLIC_VAPID_PUBLIC_KEY and VAPID_PUBLIC_KEY should contain the same public key.
